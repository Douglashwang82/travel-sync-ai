# LINE Platform
# LINE Developer Console -> your Messaging API channel -> Basic settings
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# LINE LIFF App (LINE Developer Console -> LIFF -> your app)
NEXT_PUBLIC_LIFF_ID=1234567890-xxxxxxxx
# Channel ID that issued the LIFF (for server-side ID token verification)
LIFF_CHANNEL_ID=1234567890

# LINE Login for the browser-based /app workspace.
# Create a separate "LINE Login" channel in the LINE Developers console and
# add {your-app-origin}/api/app/auth/line/callback as an allowed Callback URL.
# When both vars are set, the web sign-in page swaps the dev member picker
# for a real "Continue with LINE" OAuth2 flow.
# LINE_LOGIN_CHANNEL_ID=1234567890
# LINE_LOGIN_CHANNEL_SECRET=your_line_login_channel_secret_here
# Optional: pin the callback URL (defaults to the request origin).
# LINE_LOGIN_REDIRECT_URI=https://your-app.example.com/api/app/auth/line/callback

# Supabase
# Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon-key
# Service role key - server-side only, never expose to browser
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service-role-key

# Google AI / Cloud
# Google AI Studio -> API Keys
GEMINI_API_KEY=AIzaSy...your-gemini-api-key

# Google Maps Platform - use either the unified server-side key below,
# or individual service keys if you want separate quotas later.
# GOOGLE_MAPS_SERVER_API_KEY=AIzaSy...your-maps-platform-server-key
# Used for Places enrichment, destination timezone lookup, Routes, Weather, and Static Maps.

# Google Cloud Console -> APIs & Services -> Credentials (optional)
# If not set, vote option enrichment falls back to manual entry.
GOOGLE_PLACES_API_KEY=AIzaSy...your-places-api-key
# GOOGLE_ROUTES_API_KEY=AIzaSy...your-routes-api-key
# GOOGLE_WEATHER_API_KEY=AIzaSy...your-weather-api-key
# GOOGLE_STATIC_MAPS_API_KEY=AIzaSy...your-static-maps-api-key

# Optional Google OAuth credentials for future Calendar export/sync work.
# GOOGLE_CLIENT_ID=your-google-oauth-client-id
# GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_REDIRECT_URI=https://your-app.example.com/api/auth/google/callback

# Vercel Cron Authentication
# Any strong random secret - used to authenticate Vercel's cron scheduler.
# Generate with: openssl rand -base64 32
# Required in production. Ignored in development.
CRON_SECRET=your-strong-random-secret-here

# Sentry Error Monitoring (optional but strongly recommended)
# Sentry Dashboard -> Settings -> Projects -> your project -> Client Keys (DSN)
# Only server-side DSN needed (@sentry/node - no client bundle required)
SENTRY_DSN=https://xxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# Development only
# Enable LIFF mock mode in E2E tests (do not set in production)
# NEXT_PUBLIC_E2E_LIFF_MOCK=true
